# ─── Database (Neon Postgres) ─────────────────────────────────────────────────
# Custom name to avoid clash with marketplace storage integrations that may
# auto-inject POSTGRES_URL at runtime. The code prefers STARPRINTER_DB_URL,
# falls back to POSTGRES_URL.
STARPRINTER_DB_URL=postgresql://...neon.tech/neondb?sslmode=require

# ─── Admin (used by /login + middleware) ──────────────────────────────────────
# Plain password user types into the login form
ADMIN_PASSWORD=changeme

# Random opaque value stored in admin_session cookie + checked by middleware
# Generate: openssl rand -hex 32
ADMIN_COOKIE_SECRET=

# ─── Zoho Webhook ─────────────────────────────────────────────────────────────
# Shared secret. Zoho must send this in the `x-api-key` header.
# Generate: openssl rand -hex 32
ZOHO_API_KEY=

# ─── Vercel Cron ──────────────────────────────────────────────────────────────
# Vercel attaches `Authorization: Bearer ${CRON_SECRET}` to scheduled invocations.
# Generate: openssl rand -hex 32
CRON_SECRET=
